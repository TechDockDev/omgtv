generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
  TRIAL
  PAUSED
}

enum PhonePeRedemptionStatus {
  PENDING_NOTIFY
  NOTIFIED
  EXECUTING
  SUCCESS
  FAILED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model SubscriptionPlan {
  id               String   @id @default(uuid())
  name             String
  description      String?
  pricePaise       Int
  currency         String   @default("INR")
  durationDays     Int
  reelsLimit       Int?
  episodesLimit    Int?
  seriesLimit      Int?
  accessLevel      String?  // e.g., HD, UHD
  isUnlimitedReels Boolean  @default(false)
  isUnlimitedEpisodes Boolean @default(false)
  isUnlimitedSeries Boolean @default(false)
  isActive         Boolean  @default(true)
  
  // New UI fields
  features         String[]
  isPopular        Boolean  @default(false)
  subscriberCount  Int      @default(0)
  icon             String?  // e.g., "Zap", "Crown", "Star"
  savings          Int      @default(0) // Percentage
  cancelledPricePaise Int?  // Optional strike-through price
  subscriptionViaTrial Boolean @default(false)
  razorpayPlanId   String?
  promoVideoUrl    String?  // Optional m3u8 link for this specific plan
  
  deletedAt        DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions UserSubscription[]
  transactions  Transaction[]
}

model TrialPlan {
  id              String           @id @default(uuid())
  trialPricePaise Int
  cancelledTrialPricePaise Int?
  durationDays    Int
  reminderDays    Int
  isAutoDebit     Boolean          @default(true)
  isActive        Boolean          @default(true)
  
  subscriptions   UserSubscription[]
  transactions    Transaction[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FreePlanConfig {
  id            Int      @id @default(1)
  maxFreeReels  Int      @default(5)
  maxFreeEpisodes Int    @default(3)
  maxFreeSeries Int      @default(1)
  updatedByAdminId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([id])
}

model UserSubscription {
  id                    String              @id @default(uuid())
  userId                String
  planId                String?
  trialPlanId           String?
  status                SubscriptionStatus  @default(PENDING)
  startsAt              DateTime
  endsAt                DateTime
  razorpayOrderId       String?
  transactionId         String?
  provider              String              @default("razorpay")
  phonePeSubscriptionId String?
  mandateMaxAmount      Int?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  plan               SubscriptionPlan?    @relation(fields: [planId], references: [id])
  trialPlan          TrialPlan?           @relation(fields: [trialPlanId], references: [id])
  transaction        Transaction?         @relation("TransactionUserSubscriptions", fields: [transactionId], references: [id])
  phonePeRedemptions PhonePeRedemption[]

  @@index([userId, status])
  @@index([planId])
  @@index([transactionId])
  @@index([provider])
  @@index([phonePeSubscriptionId])
}

model Transaction {
  id                 String             @id @default(uuid())
  userId             String
  planId             String?
  amountPaise        Int
  currency           String             @default("INR")
  status             TransactionStatus  @default(PENDING)
  razorpayPlanId     String?
  razorpayPaymentId  String?
  razorpaySignature  String?
  subscriptionId     String?
  trialPlanId        String?
  failureReason      String?
  metadata           Json?
  provider           String             @default("razorpay")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  plan          SubscriptionPlan?   @relation(fields: [planId], references: [id])
  trialPlan     TrialPlan?          @relation(fields: [trialPlanId], references: [id])
  subscriptions UserSubscription[]  @relation("TransactionUserSubscriptions")

  @@index([userId, status])
  @@index([razorpayPlanId])
  @@index([subscriptionId])
  @@index([razorpayPaymentId])
  @@index([provider])
}

model PhonePeRedemption {
  id                     String                   @id @default(uuid())
  userId                 String
  userSubscriptionId     String
  merchantSubscriptionId String
  merchantOrderId        String                   @unique
  amount                 Int
  isTrialCycle           Boolean                  @default(false)
  cycleNumber            Int
  mandateMaxAmount       Int                      @default(50000)
  scheduledNotifyAt      DateTime
  status                 PhonePeRedemptionStatus  @default(PENDING_NOTIFY)
  notifiedAt             DateTime?
  notifyWindowEnd        DateTime?
  executeAttempts        Int                      @default(0)
  lastError              String?
  lastStatusCheckedAt    DateTime?
  metadata               Json?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  userSubscription UserSubscription @relation(fields: [userSubscriptionId], references: [id])

  @@unique([userSubscriptionId, cycleNumber])
  @@unique([userSubscriptionId, scheduledNotifyAt])
  @@index([userId])
  @@index([userSubscriptionId])
  @@index([status, scheduledNotifyAt])
  @@index([status, notifiedAt])
  @@index([status, updatedAt])
}

model PhonePeEventLog {
  id                     String   @id @default(uuid())
  userId                 String?
  merchantOrderId        String?
  merchantSubscriptionId String?
  eventType              String
  direction              String
  request                Json?
  response               Json?
  httpStatus             Int?
  success                Boolean
  createdAt              DateTime @default(now())

  @@index([merchantOrderId])
  @@index([merchantSubscriptionId])
  @@index([userId])
  @@index([createdAt])
  @@index([eventType])
  @@index([createdAt, eventType])
}

model SubscriptionGlobalConfig {
  id                   Int      @id @default(1)
  promoVideoUrl        String?
  restrictRepeatTrials Boolean  @default(false)
  updatedByAdminId     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([id])
}


model UserWallet {
  id        String   @id @default(uuid())
  userId    String   @unique

  status    WalletStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WalletStatus {
  ACTIVE
  BLOCKED
}

model CoinTransaction {
  id              String   @id @default(uuid())
  userId          String

  type            CoinTransactionType
  source          TransactionSource

  amount          Int
  remainingAmount Int?     // ✅ CRITICAL (for safe debit)

  referenceId     String?  @unique

  expiryAt        DateTime? // Phase 2 (earned coins)

  metadata        Json?

  reminderSentAt  DateTime?

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, expiryAt])
  @@index([userId, type, remainingAmount])
  @@index([expiryAt, reminderSentAt])
}

enum CoinTransactionType {
  CREDIT
  DEBIT
}

enum TransactionSource {
  PURCHASE
  UNLOCK
  ADMIN
  AD
  EXPIRY
  STREAK
  STREAK_BONUS
}

enum StreakStatus {
  ACTIVE
  BROKEN
}

model CoinBundle {
  id        String   @id @default(uuid())

  title     String
  coins     Int
  price     Int
  currency  String   @default("INR")

  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCoinPurchase {
  id          String   @id @default(uuid())

  userId      String
  bundleId    String

  orderId     String?  // payment gateway order
  paymentId   String?  @unique

  amountPaid  Int
  coins       Int

  status      PurchaseStatus

  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@unique([orderId])
}

enum PurchaseStatus {
  CREATED
  SUCCESS
  FAILED
}

model AdCoinConfig {
  id               Int      @id @default(1)
  isEnabled        Boolean  @default(true)
  coinsPerAd       Int      @default(5)
  dailyLimit       Int      @default(3)
  expiryHours      Int?
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([id])
}

model UserEpisodeUnlock {
  id         String   @id @default(uuid())

  userId     String
  episodeId  String

  createdAt  DateTime @default(now())

  @@unique([userId, episodeId])
}

// ── Streak System ─────────────────────────────────────────────────────────────

model StreakConfig {
  id               Int      @id @default(1)
  isEnabled        Boolean  @default(true)
  coinsPerDay      Int      @default(10)
  coinExpiryHours  Int?
  version          Int      @default(1)
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([id])
}

model StreakMilestone {
  id               String   @id @default(uuid())
  configVersion    Int
  dayNumber        Int
  bonusCoins       Int
  bonusExpiryHours Int?
  isEnabled        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([configVersion, dayNumber])
  @@index([configVersion, isEnabled])
}

model UserStreak {
  id               String       @id @default(uuid())
  userId           String       @unique
  currentDay       Int          @default(1)
  lastClaimedAt    DateTime?
  cyclesCompleted  Int          @default(0)
  cycleStartedAt   DateTime     @default(now())
  configVersion    Int
  status           StreakStatus @default(ACTIVE)
  lastBrokeAtDay       Int?
  streakReminderSentAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([status])
  @@index([configVersion])
  @@index([lastClaimedAt])
  @@index([lastClaimedAt, streakReminderSentAt])
}

model StreakClaimLog {
  id            String   @id @default(uuid())
  userId        String
  dayNumber     Int
  coinsEarned   Int
  bonusEarned   Int      @default(0)
  milestoneId   String?
  cycleNumber   Int
  configVersion Int
  claimedAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, claimedAt])
  @@index([dayNumber])
  @@index([milestoneId])
}
